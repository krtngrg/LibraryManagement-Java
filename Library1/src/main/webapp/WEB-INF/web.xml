<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Library Management System</display-name>
    <description>Complete Library Management System with Admin and Librarian modules</description>

    <!-- Welcome File List -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

    <!-- Session Configuration -->
    <session-config>
        <session-timeout>30</session-timeout> <!-- 30 minutes -->
    </session-config>

    <!-- MIME Type Mappings -->
    <mime-mapping>
        <extension>css</extension>
        <mime-type>text/css</mime-type>
    </mime-mapping>

    <mime-mapping>
        <extension>js</extension>
        <mime-type>application/javascript</mime-type>
    </mime-mapping>

    <mime-mapping>
        <extension>woff</extension>
        <mime-type>application/font-woff</mime-type>
    </mime-mapping>

    <mime-mapping>
        <extension>woff2</extension>
        <mime-type>application/font-woff2</mime-type>
    </mime-mapping>

    <!-- Character Encoding Filter -->
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>org.apache.catalina.filters.SetCharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
        <init-param>
            <param-name>ignore</param-name>
            <param-value>false</param-value>
        </init-param>
    </filter>

    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 
    Note: Authentication and Role filters are commented out until implemented
    Uncomment these after creating the filter classes
    
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.library.filter.AuthFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
        <url-pattern>/librarian/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>RoleFilter</filter-name>
        <filter-class>com.library.filter.RoleFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
        <url-pattern>/librarian/*</url-pattern>
    </filter-mapping>
    -->

    <!-- Servlet Definitions -->
    
    <!-- Authentication Servlets -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.library.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.library.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SignupServlet</servlet-name>
        <servlet-class>com.library.controller.SignupServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SignupServlet</servlet-name>
        <url-pattern>/signup</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>OTPVerificationServlet</servlet-name>
        <servlet-class>com.library.controller.OTPVerificationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OTPVerificationServlet</servlet-name>
        <url-pattern>/verify-otp</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ForgotPasswordServlet</servlet-name>
        <servlet-class>com.library.controller.ForgotPasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ForgotPasswordServlet</servlet-name>
        <url-pattern>/forgot-password</url-pattern>
    </servlet-mapping>

    <!-- Admin Servlets -->
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>com.library.controller.admin.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ManageUsersServlet</servlet-name>
        <servlet-class>com.library.controller.admin.ManageUsersServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ManageUsersServlet</servlet-name>
        <url-pattern>/admin/manage-users</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SystemReportsServlet</servlet-name>
        <servlet-class>com.library.controller.admin.SystemReportsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SystemReportsServlet</servlet-name>
        <url-pattern>/admin/reports</url-pattern>
    </servlet-mapping>

    <!-- Librarian Servlets -->
    <servlet>
        <servlet-name>LibrarianDashboardServlet</servlet-name>
        <servlet-class>com.library.controller.librarian.LibrarianDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LibrarianDashboardServlet</servlet-name>
        <url-pattern>/librarian/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ManageBooksServlet</servlet-name>
        <servlet-class>com.library.controller.librarian.ManageBooksServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ManageBooksServlet</servlet-name>
        <url-pattern>/librarian/manage-books</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ManageStudentsServlet</servlet-name>
        <servlet-class>com.library.controller.librarian.ManageStudentsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ManageStudentsServlet</servlet-name>
        <url-pattern>/librarian/manage-students</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>IssueBookServlet</servlet-name>
        <servlet-class>com.library.controller.librarian.IssueBookServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>IssueBookServlet</servlet-name>
        <url-pattern>/librarian/issue-book</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReturnBookServlet</servlet-name>
        <servlet-class>com.library.controller.librarian.ReturnBookServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReturnBookServlet</servlet-name>
        <url-pattern>/librarian/return-book</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TransactionReportsServlet</servlet-name>
        <servlet-class>com.library.controller.librarian.TransactionReportsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TransactionReportsServlet</servlet-name>
        <url-pattern>/librarian/reports</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BookRecommendationServlet</servlet-name>
        <servlet-class>com.library.controller.librarian.BookRecommendationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BookRecommendationServlet</servlet-name>
        <url-pattern>/librarian/recommendations</url-pattern>
    </servlet-mapping>

    <!-- Error Pages (Optional - create these JSP files if needed) -->
    <!--
